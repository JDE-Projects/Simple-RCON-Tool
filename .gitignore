# --- Simple RCON Tool .gitignore ---

# Runtime data: holds your real hosts and ports. Never commit.
servers.json

# Exported console logs written next to the app
*_Console_*.txt

# Optional debug logs (written next to the exe when the toggle is on)
Debug_Log_*.txt

# User preferences (theme choice, persisted next to the exe)
*.pref

# PyInstaller build output
build/
dist/
*.spec

# Python cache
__pycache__/
*.pyc
.venv/

# Local-only test launcher (kept out of the repo on purpose)
Launch_*.bat

# Local planning notes (kept private, not shared)
roadmap.md
status.md
needs-fixed.md
